{
  "name": "@generic-ai/plugin-storage-sqlite",
  "version": "0.0.0",
  "description": "Durable SQLite-backed storage implementation for Generic AI. Default local persistence for the starter preset.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -b --noEmit --pretty false"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT",
  "genericAi": {
    "kind": "plugin",
    "category": "infra",
    "method": "sqlite-storage.v1"
  },
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
