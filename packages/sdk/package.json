{
  "name": "@generic-ai/sdk",
  "version": "0.0.0",
  "description": "Framework-facing SDK contracts and typed helpers that plugins and presets depend on when building against Generic AI.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./pi": {
      "types": "./dist/pi/index.d.ts",
      "default": "./dist/pi/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "pi": [
        "dist/pi/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "zod": "^4.3.6",
    "@mariozechner/pi-coding-agent": "0.70.2"
  }
}
