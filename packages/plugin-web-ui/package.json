    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./agent-tools": {
      "types": "./dist/agent-tools.d.ts",
      "default": "./dist/agent-tools.js"
    },
    "./styles.css": "./styles.css"
  },
  "files": [
    "dist/agent-tools.d.ts",
    "dist/agent-tools.d.ts.map",
    "dist/agent-tools.js",
    "dist/agent-tools.js.map",
    "dist/client.d.ts",
    "dist/client.d.ts.map",
    "dist/client.js",
    "dist/client.js.map",
    "dist/components",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/index.js",
    "dist/index.js.map",
    "dist/lib",
    "dist/server.d.ts",
    "dist/server.d.ts.map",
    "dist/server.js",
    "dist/server.js.map",
    "dist/templates.d.ts",
    "dist/templates.d.ts.map",
    "dist/templates.js",
    "dist/templates.js.map",
    "dist/types.d.ts",
    "dist/types.d.ts.map",
    "dist/types.js",
    "dist/types.js.map",
    "styles.css",
    "README.md"
  ],
  "dependencies": {
    "@generic-ai/plugin-config-yaml": "0.0.0",
    "@generic-ai/plugin-hono": "0.0.0",
    "@generic-ai/sdk": "0.0.0",
    "@sinclair/typebox": "0.34.49",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "ai": "^6.0.168",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.15",
    "lucide-react": "^1.11.0",
