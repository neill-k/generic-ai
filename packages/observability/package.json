{
  "name": "@generic-ai/observability",
  "version": "0.0.0",
  "description": "Local-first observability surface for Generic AI runs, traces, metrics, reports, and read-only operator panels.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./agent-tools": {
      "types": "./dist/agent-tools.d.ts",
      "default": "./dist/agent-tools.js"
    },
    "./otel": {
      "types": "./dist/otel.d.ts",
      "default": "./dist/otel.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -b --pretty false && rimraf --glob dist *.tsbuildinfo"
  },
  "files": [
    "dist",
    "src/styles.css",
    "README.md"
  ],
  "dependencies": {
    "@generic-ai/sdk": "0.0.0",
    "hono": "^4.12.15"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
