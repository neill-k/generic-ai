{
  "name": "@generic-ai/monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Generic AI Framework monorepo root. Plugin-first multi-agent framework built on pi. See docs/planning for the authoritative planning baseline.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "overrides": {
    "@mariozechner/pi-ai": {
      "@anthropic-ai/sdk": "0.91.1"
    }
  },
  "scripts": {
    "check:node": "node scripts/check-node-version.mjs",
    "preinstall": "node scripts/check-node-version.mjs",
    "pretypecheck": "node scripts/check-node-version.mjs",
    "pretypecheck:build": "node scripts/check-node-version.mjs",
    "pretypecheck:tests": "node scripts/check-node-version.mjs",
    "build": "tsc -b",
    "prebuild": "node scripts/check-node-version.mjs",
    "typecheck": "npm run typecheck:build && npm run typecheck:tests && rimraf --glob \"packages/*/dist\" \"packages/*/*.tsbuildinfo\" \"examples/*/dist\" \"examples/*/*.tsbuildinfo\"",
    "typecheck:build": "tsc -b --pretty",
    "typecheck:tests": "tsc -p tsconfig.test.json --pretty",
    "pretest": "node scripts/check-node-version.mjs",
    "test": "vitest run",
    "prelint": "node scripts/check-node-version.mjs",
    "check:boundaries": "node scripts/check-package-boundaries.mjs",
    "check:biome-helper-ignores": "node scripts/check-biome-helper-ignores.mjs",
    "lint": "npm run check:boundaries && npm run check:biome-helper-ignores && biome lint README.md CONTRIBUTING.md RELEASING.md biome.json package.json tsconfig.json tsconfig.base.json tsconfig.test.json vitest.config.ts docs packages examples scripts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "docs": "node scripts/generate-docs.mjs",
    "docs:check": "node scripts/generate-docs.mjs --check",
    "clean": "rimraf --glob \"packages/*/dist\" \"packages/*/*.tsbuildinfo\" \"examples/*/dist\" \"examples/*/*.tsbuildinfo\" node_modules",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version && npm install --package-lock-only",
    "changeset:publish": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@changesets/cli": "2.31.0",
    "@types/node": "24.12.2",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
