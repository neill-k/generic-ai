{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://generic-ai.dev/contracts/config/harness.schema.json",
  "title": "Generic AI Harness Config (YAML Concern)",
  "description": "Canonical schema for .generic-ai/harnesses/*.yaml.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "displayName": {
      "type": "string"
    },
    "adapter": {
      "type": "string",
      "enum": ["pi", "external"]
    },
    "controller": {
      "type": "string",
      "const": "model-directed"
    },
    "model": {
      "type": "string"
    },
    "primaryAgent": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "policyProfile": {
      "type": "string",
      "enum": ["local-dev-full", "benchmark-container"]
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "kind": {
            "type": "string",
            "enum": ["root", "planner", "explorer", "builder", "verifier", "custom"]
          },
          "description": {
            "type": "string"
          },
          "instructions": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "readOnly": {
            "type": "boolean"
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    },
    "loop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stages"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "pattern": {
          "type": "string",
          "pattern": "^(thread-turn-tool-policy|custom\\.[A-Za-z0-9._-]+)$"
        },
        "stateModel": {
          "type": "string",
          "pattern": "^(thread-turn-item|custom\\.[A-Za-z0-9._-]+)$"
        },
        "entryStage": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "terminalStages": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "uniqueItems": true
        },
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "kind"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "state",
                  "context-builder",
                  "controller",
                  "tool-router",
                  "policy-gate",
                  "executor",
                  "verifier",
                  "custom"
                ]
              },
              "roleRef": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
              },
              "description": {
                "type": "string"
              },
              "tools": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "uniqueItems": true
              },
              "effects": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^(fs\\.read|fs\\.write|process\\.spawn|network\\.egress|mcp\\.read|mcp\\.launch|memory\\.read|memory\\.write|handoff\\.read|handoff\\.write|artifact\\.write|repo\\.inspect|lsp\\.read|secret\\.read|sandbox\\.create|custom\\.[A-Za-z0-9._-]+)$"
                },
                "uniqueItems": true
              },
              "readOnly": {
                "type": "boolean"
              },
              "metadata": {
                "type": "object"
              }
            }
          }
        },
        "transitions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to"],
            "properties": {
              "from": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
              },
              "to": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
              },
              "label": {
                "type": "string"
              },
              "metadata": {
                "type": "object"
              }
            }
          }
        },
        "invariants": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "allowNetwork": {
      "type": "boolean"
    },
    "allowMcp": {
      "type": "boolean"
    },
    "artifactDir": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    }
  }
}
