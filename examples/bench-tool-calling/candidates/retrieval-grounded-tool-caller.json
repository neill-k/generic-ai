{
  "kind": "generic-ai.harness",
  "schemaVersion": "0.1",
  "id": "harness.micro.retrieval-grounded-tool-caller",
  "name": "Retrieval-grounded tool caller",
  "description": "Retrieves the policy chunk before calling the final answer function.",
  "packages": [
    {
      "id": "capability.retrieval",
      "package": "@generic-ai/bench-tool-calling/retrieval",
      "version": "0.1.0"
    },
    {
      "id": "capability.function-calling",
      "package": "@generic-ai/bench-tool-calling/functions",
      "version": "0.1.0"
    },
    {
      "id": "grader.default",
      "package": "@generic-ai/grader-default",
      "version": "0.1.0"
    }
  ],
  "agents": [
    {
      "id": "solver",
      "role": "solver",
      "instructions": "Retrieve the matching benefits policy chunk, call answer_from_policy_chunk, and cite the chunk id.",
      "packageRefs": ["capability.retrieval", "capability.function-calling", "grader.default"],
      "artifactRefs": ["artifact.tool-call-trace", "artifact.answer"]
    }
  ],
  "protocols": [
    {
      "id": "retrieve-then-call",
      "protocol": "pipeline",
      "packageRef": "capability.function-calling",
      "actorRefs": ["solver"]
    }
  ],
  "artifacts": [
    {
      "id": "artifact.tool-call-trace",
      "name": "tool-call-trace.json",
      "kind": "trace",
      "producedBy": ["solver"]
    },
    {
      "id": "artifact.answer",
      "name": "grounded-answer.md",
      "kind": "report",
      "producedBy": ["solver"]
    }
  ],
  "missionRefs": ["mission.micro.tool-calling-retrieval"],
  "evalRefs": ["benchmark.micro.tool-calling-retrieval.v0"]
}
