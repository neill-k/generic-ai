{
  "kind": "generic-ai.harness",
  "schemaVersion": "0.1",
  "id": "harness.meso.policy-gated-tool-planner",
  "name": "Policy-gated tool planner",
  "description": "Checks policy before selecting refund tools and records the audit evidence.",
  "packages": [
    {
      "id": "capability.policy",
      "package": "@generic-ai/bench-policy-tools/policy",
      "version": "0.1.0"
    },
    {
      "id": "capability.order-tools",
      "package": "@generic-ai/bench-policy-tools/order-tools",
      "version": "0.1.0"
    },
    {
      "id": "capability.audit-log",
      "package": "@generic-ai/bench-policy-tools/audit-log",
      "version": "0.1.0"
    },
    {
      "id": "grader.default",
      "package": "@generic-ai/grader-default",
      "version": "0.1.0"
    }
  ],
  "agents": [
    {
      "id": "planner",
      "role": "planner",
      "instructions": "Check refund policy, read the order, call the allowed refund tool, then hand evidence to the auditor.",
      "packageRefs": ["capability.policy", "capability.order-tools", "grader.default"],
      "artifactRefs": ["artifact.tool-plan"]
    },
    {
      "id": "auditor",
      "role": "auditor",
      "instructions": "Write an audit note that cites the policy id, order id, and refund id.",
      "packageRefs": ["capability.audit-log", "grader.default"],
      "artifactRefs": ["artifact.audit-note"]
    }
  ],
  "protocols": [
    {
      "id": "policy-gated-sequence",
      "protocol": "pipeline",
      "packageRef": "capability.policy",
      "actorRefs": ["planner", "auditor"]
    }
  ],
  "artifacts": [
    {
      "id": "artifact.tool-plan",
      "name": "tool-plan.json",
      "kind": "trace",
      "producedBy": ["planner"]
    },
    {
      "id": "artifact.audit-note",
      "name": "audit-note.md",
      "kind": "report",
      "producedBy": ["auditor"]
    }
  ],
  "missionRefs": ["mission.meso.policy-tools-refund"],
  "evalRefs": ["benchmark.meso.policy-tools-refund.v0"]
}
