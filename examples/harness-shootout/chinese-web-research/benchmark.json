    "cases": [
      {
        "id": "policy-date-reconciliation",
        "taskRef": "task.policy-date-reconciliation",
        "queryLanguage": "zh-CN",
        "expectedAnswerLanguage": "zh-CN",
        "domain": "public-policy",
        "answerUniqueness": "multi-hop-unique",
        "requiredSourceRefs": ["source.current-guidance", "source.archive-notice"],
        "citationRequired": true,
        "requiresCrossSourceReconciliation": true,
        "staleSourceRefs": ["source.stale-blog"],
