{
  "kind": "generic-ai.benchmark",
  "schemaVersion": "0.1",
  "id": "benchmark.chinese-web-research.v0",
  "missionRef": "mission.chinese-web-research",
  "hypothesis": "A harness that treats Chinese web research as source-grounded evidence can preserve answer correctness while surfacing citation coverage, cross-source reconciliation, stale-source use, and Chinese text handling.",
  "candidates": [
    {
      "id": "source-aware-researcher",
      "harnessRef": "harness.chinese-web-research.source-aware-researcher"
    },
    {
      "id": "citation-naive-researcher",
      "harnessRef": "harness.chinese-web-research.citation-naive-researcher"
    }
  ],
  "primaryMetric": "answer_correctness",
  "metricDefinitions": [
    {
      "id": "answer_correctness",
      "name": "Answer correctness",
      "unit": "ratio",
      "direction": "higher_is_better",
      "source": "grader",
      "description": "Whether the final answer matches the fixture-grounded answer."
    },
    {
      "id": "source_provenance",
      "name": "Source provenance",
      "unit": "ratio",
      "direction": "higher_is_better",
      "source": "report",
      "description": "Whether required fixture sources are cited for citation-bearing tasks."
    },
    {
      "id": "cross_source_reconciliation",
      "name": "Cross-source reconciliation",
      "unit": "ratio",
      "direction": "higher_is_better",
      "source": "report",
      "description": "Whether multi-source tasks reconcile the required sources."
    },
    {
      "id": "stale_source_avoidance",
      "name": "Stale source avoidance",
      "unit": "ratio",
      "direction": "higher_is_better",
      "source": "report",
      "description": "Whether stale or superseded source snippets were avoided."
    },
    {
      "id": "chinese_text_preservation",
      "name": "Chinese text preservation",
      "unit": "ratio",
      "direction": "higher_is_better",
      "source": "artifact",
      "description": "Whether Chinese source titles and snippets remained intact in evidence artifacts."
    }
  ],
  "guardrailMetrics": [
    "source_provenance",
    "cross_source_reconciliation",
    "stale_source_avoidance",
    "chinese_text_preservation"
  ],
  "webResearch": {
    "id": "chinese-web-research-v0",
    "locale": "zh-CN",
    "liveSearch": {
      "enabledByDefault": false,
      "providerAgnostic": true,
      "requiredEnvVars": ["GENERIC_AI_WEB_SEARCH_PROVIDER"],
      "skipReason": "Deterministic fixtures are the default; live Chinese web/search runs are opt-in and provider-gated."
    },
    "sources": [
      {
