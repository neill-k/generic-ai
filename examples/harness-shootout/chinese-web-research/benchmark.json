      },
      {
        "id": "dataset-name-disambiguation",
        "taskRef": "task.dataset-name-disambiguation",
        "queryLanguage": "zh-CN",
        "expectedAnswerLanguage": "zh-CN",
        "domain": "research-benchmark",
        "answerUniqueness": "multi-hop-unique",
        "requiredSourceRefs": ["source.dataset-paper", "source.benchmark-summary"],
        "citationRequired": true,
        "requiresCrossSourceReconciliation": true,
        "rationale": "The answer should cite both the task-set description and benchmark summary while preserving Chinese evidence snippets."
      }
