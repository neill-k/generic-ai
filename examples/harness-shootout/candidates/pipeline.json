{
  "kind": "generic-ai.harness",
  "schemaVersion": "0.1",
  "id": "harness.pipeline",
  "name": "Pipeline",
  "packages": [
    {
      "id": "protocol.pipeline",
      "package": "@generic-ai/protocol-pipeline",
      "version": "0.1.0"
    },
    {
      "id": "capability.files",
      "package": "@generic-ai/plugin-tools-files",
      "version": "0.1.0"
    },
    {
      "id": "capability.terminal",
      "package": "@generic-ai/plugin-tools-terminal-sandbox",
      "version": "0.1.0"
    },
    {
      "id": "grader.default",
      "package": "@generic-ai/grader-default",
      "version": "0.1.0"
    }
  ],
  "agents": [
    {
      "id": "implementer",
      "role": "implementer",
      "instructions": "Plan, implement, test, review, and finalize in fixed order.",
      "packageRefs": ["protocol.pipeline", "capability.files", "capability.terminal"]
    }
  ],
  "protocols": [
    {
      "id": "pipeline",
      "protocol": "pipeline",
      "packageRef": "protocol.pipeline",
      "actorRefs": ["implementer"]
    }
  ],
  "artifacts": [
    {
      "id": "artifact.patch",
      "name": "implementation.patch",
      "kind": "patch",
      "producedBy": ["implementer"]
    }
  ],
  "missionRefs": ["mission.oauth-login"],
  "evalRefs": ["benchmark.package-composed-shootout.v0"]
}
