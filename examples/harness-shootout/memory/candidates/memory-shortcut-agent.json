{
  "kind": "generic-ai.harness",
  "schemaVersion": "0.1",
  "id": "harness.memory.shortcut-agent",
  "name": "Memory-Shortcut Agent",
  "packages": [
    {
      "id": "protocol.pipeline",
      "package": "@generic-ai/protocol-pipeline",
      "version": "0.1.0"
    },
    {
      "id": "capability.memory",
      "package": "@generic-ai/plugin-memory-files",
      "version": "0.1.0"
    },
    {
      "id": "capability.messaging",
      "package": "@generic-ai/plugin-messaging",
      "version": "0.1.0"
    },
    {
      "id": "grader.memory-profile",
      "package": "@generic-ai/grader-memory-profile",
      "version": "0.1.0"
    }
  ],
  "agents": [
    {
      "id": "shortcut-agent",
      "role": "builder",
      "instructions": "Answer from the most convenient memory summary and repair final text only when the grader rejects it.",
      "packageRefs": ["capability.memory", "capability.messaging"],
      "artifactRefs": ["artifact.memory-answer"]
    },
    {
      "id": "summary-checker",
      "role": "verifier",
      "instructions": "Check final answer utility, but do not require detailed memory provenance.",
      "packageRefs": ["protocol.pipeline", "grader.memory-profile"],
      "artifactRefs": ["artifact.memory-audit"]
    }
  ],
  "protocols": [
    {
      "id": "pipeline",
      "protocol": "pipeline",
      "packageRef": "protocol.pipeline",
      "actorRefs": ["shortcut-agent", "summary-checker"]
    }
  ],
  "artifacts": [
    {
      "id": "artifact.memory-answer",
      "name": "memory-answer.md",
      "kind": "message",
      "producedBy": ["shortcut-agent"],
      "reviewedBy": ["summary-checker"]
    },
    {
      "id": "artifact.memory-audit",
      "name": "memory-audit.json",
      "kind": "report",
      "producedBy": ["summary-checker"],
      "reviewedBy": ["summary-checker"]
    }
  ],
  "missionRefs": ["mission.memory-profile"],
  "evalRefs": ["benchmark.memory-profile.v0"]
}
